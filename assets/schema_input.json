{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-schema/example/master/assets/schema_input.json",
    "title": "nf-meta-gwas samplesheet schema",
    "description": "Schema for the samplesheet file",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "phenotype": {
                "type": "string",
                "errorMessage": "Phenotype must be provided"
            },
            "trait_type": {
                "type": "string",
                "enum": ["binary", "continuous"],
                "errorMessage": "Type must be either 'binary' or 'continuous'"
            },
            "population": {
                "type": "string",
                "enum" : ["eur", "afr", "amr", "eas", "csa", "mid"],
                "errorMessage": "Population must be one of the following: eur, afr, amr, eas, csa, or mid"
            },
            "cohort" : {
                "type" : "string",
                "errorMessage" : "Cohort is required"
            },
            "col_overrides": {
                "type": "string",
                "description": "Optional column name overrides as comma-separated key=value pairs (e.g. snpid=rsid,chrom=chr,pos=bp,ea=A1,nea=A2,beta=b,se=se,eaf=af). When provided, all 7 required keys (chrom, pos, ea, nea, beta, se, eaf) must be present.",
                "pattern": "^$|^[a-zA-Z_][a-zA-Z0-9_]*=[^,=]+(,[a-zA-Z_][a-zA-Z0-9_]*=[^,=]+)*$",
                "errorMessage": "col_overrides must be empty or formatted as key=value pairs separated by commas"
            }
        },
        "required": ["phenotype", "trait_type", "population", "cohort"]
    }
}