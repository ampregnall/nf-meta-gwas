conda.enabled = true
conda.cacheDir = "${projectDir}/.conda_cache"

plugins {
    id 'nf-schema@2.1.1'
}

params {
    input   = null
    output  = "results"
    mac     = 50
    dbsnp = "/project/voltron/Resources/dbSNP157/SNPlocs.Hsapiens.dbSNP157.GRCh38_0.99.24.tar.gz"
    
}

profiles {

    standard {
        includeConfig 'conf/base.config'
    }

  voltron {
      process.executor = 'lsf'
      process.queue = 'voltron_normal'
      singularity.enabled = true
      singularity.runOptions = '-B /root/,/project/,/static/'   
      // process.beforeScript = 'module load apptainer'          
      executor {
          queueSize = 500
      }
      process.memory = '16GB'
  }
}

process {
  withName: MUNGE_SUMSTATS {
    conda = "${projectDir}/envs/munge.yaml"
  }
}
